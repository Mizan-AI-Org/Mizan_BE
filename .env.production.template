STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform Admin (/admin) — comma-separated emails
PLATFORM_OPS_EMAILS=
PLATFORM_OPS_SUPERUSER_EMAILS=
